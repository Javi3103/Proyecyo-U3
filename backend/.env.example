# Copiar como variables de entorno reales antes de ejecutar la app.
# Nunca commitear un archivo .env con valores reales (ver backend/.gitignore).

DB_URL=jdbc:postgresql://localhost:5432/master_gateway
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Generar con: openssl rand -base64 32
JWT_SECRET=

JWT_TEMP_EXPIRATION_MS=300000
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
